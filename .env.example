# Copy to .env and fill in. .env is gitignored.

# GitHub Personal Access Token (classic, public_repo scope is enough).
# Without this, GitHub REST is limited to 60 req/hr; with it, 5000 req/hr.
GITHUB_TOKEN=

# LM Studio local server (start it from LM Studio: Developer tab -> Start Server).
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# Ollama local server (default port).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Where the SQLite cache for trust-engine calls lives.
PACKAGEGUARD_CACHE=.cache/trust_cache.sqlite
